# Example env file for development — DO NOT commit real secrets
# Copy to .env and fill values locally. Add .env to .gitignore.

# JWT
JWT_SECRET=

# Uploads
# Absolute path to base dir (optional). If not set, repository's uploads/ is used.
UPLOAD_ABS_DIR=
UPLOAD_BASE_URL=

# Tencent COS (optional)
COS_SECRET_ID=TCLOUD_SECRET_ID_PLACEHOLDER
COS_SECRET_KEY=TCLOUD_SECRET_KEY_PLACEHOLDER
COS_BUCKET=your-cos-bucket-name
COS_REGION=ap-beijing
COS_BASE_URL=https://your-bucket.cos.ap-beijing.myqcloud.com

# AI keys and models
# Text model configuration (AI 写稿使用)
# - Set either `OPENAI_API_KEY` (OpenAI-compatible) or `AI_TEXT_API_KEY` to enable
#   the news writer. Use `AI_TEXT_MODEL` or `OPENAI_MODEL` to choose the model name.
OPENAI_API_KEY=
AI_TEXT_API_KEY=
AI_TEXT_MODEL=
OPENAI_MODEL=

# Vision provider keys / model names
# - Set `AI_VISION_API_KEY` for vision calls and `AI_VISION_MODEL` for the model name.
AI_VISION_API_KEY=
AI_VISION_MODEL=
# Optional override for vision model used by ai_for_tags (defaults to qwen2-vl-72b-instruct)
# Note: `VISION_MODEL` is deprecated; use `AI_VISION_MODEL` instead.

# Face detector (optional, used by /api/faces/detect when no faces payload provided)
# FACE_DETECTOR_BACKEND=auto|insightface|opencv_haar
FACE_DETECTOR_BACKEND=auto
FACE_DETECTOR_MODEL_NAME=buffalo_sc
FACE_DETECTOR_PYTHON_PATH=python
FACE_DETECTOR_SCRIPT_PATH=
FACE_DETECTOR_TIMEOUT_MS=45000
FACE_DETECTOR_FETCH_TIMEOUT_MS=20000
FACE_DETECTOR_MAX_IMAGE_BYTES=15728640
FACE_DETECTOR_USE_THUMB=0
FACE_DETECTOR_USE_SERVICE=1
FACE_DETECTOR_SERVICE_URL=http://127.0.0.1:8009
FACE_DETECTOR_SERVICE_TIMEOUT_MS=20000
FACE_DETECTOR_SERVICE_REQUIRED=0
FACE_AUTO_WORKER_CONCURRENCY=1
FACE_AUTO_USE_BULLMQ=0
FACE_AUTO_WORKER_ENABLE=1
FACE_AUTO_QUEUE_NAME=face-auto-jobs
REDIS_URL=
FACE_CLUSTER_MATCH_THRESHOLD=0.36
FACE_CLUSTER_WEAK_THRESHOLD=0.28
FACE_CLUSTER_TOPK=5
FACE_CLUSTER_AUTO_CREATE_PERSON=1
FACE_CLUSTER_CANDIDATE_LIMIT=5000
FACE_CLUSTER_UNIQUE_PERSON_PER_PHOTO=1

# Public demo scope (optional)
# When frontend requests /api/projects/* with ?demo=1 and user is not logged in,
# backend will use this organization id for read-only demo access.
DEMO_ORGANIZATION_ID=

# MySQL database connection
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
#