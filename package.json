{
  "name": "imgmgr-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node app.js",
    "db:export": "node scripts/export_db_artifacts.js",
    "db:migrate": "node scripts/run_migrations.js",
    "db:seed": "node scripts/run_seed_minimal.js",
    "db:bootstrap": "npm run db:migrate && npm run db:seed",
    "db:share": "node scripts/run_create_share_tables.js",
    "face:deps": "python -m pip install -r scripts/requirements-face.txt",
    "face:service": "python -m uvicorn scripts.face_embed_service:app --host 127.0.0.1 --port 8009",
    "face:backfill": "node scripts/backfill_faces.js",
    "image:backfill": "node scripts/backfill_image_embeddings.js",
    "video:playback:backfill": "node scripts/backfill_video_playback.js",
    "storage:cors": "node scripts/configure_storage_cors.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "ai:tags:backfill": "node scripts/backfill_ai_tags.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-storage": "3.1075.0",
    "@aws-sdk/s3-presigned-post": "3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.3",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.58.5",
    "cheerio": "^1.2.0",
    "dotenv": "^16.1.4",
    "express": "^5.1.0",
    "heic-convert": "^2.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.2.0",
    "mysql2": "^3.15.3",
    "node-fetch": "^2.6.7",
    "nodemailer": "^9.0.3",
    "openai": "^6.10.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.15.0"
  }
}
